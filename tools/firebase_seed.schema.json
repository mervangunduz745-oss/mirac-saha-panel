{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mirac.local/schemas/firebase-seed-collection-v1.json",
  "title": "Mirac ERP Firestore subcollection seed file",
  "type": "object",
  "required": ["collectionPath", "documents"],
  "additionalProperties": false,
  "properties": {
    "collectionPath": {
      "type": "string",
      "pattern": "^orgs/[A-Za-z0-9_-]{2,120}/[A-Za-z][A-Za-z0-9]*$"
    },
    "documents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "path", "data"],
        "additionalProperties": false,
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "path": {"type": "string", "minLength": 1},
          "data": {
            "type": "object",
            "required": ["legacyId", "schemaVersion", "importBatchId"],
            "properties": {
              "legacyId": {"type": "string", "minLength": 1},
              "schemaVersion": {"type": "integer", "minimum": 1},
              "importBatchId": {"type": "string", "minLength": 3}
            },
            "additionalProperties": true
          }
        }
      }
    }
  }
}
